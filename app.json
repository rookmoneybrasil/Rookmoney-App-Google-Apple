{
  "expo": {
    "name": "Rook Money",
    "slug": "rook-money",
    "scheme": "rookmoney",
    "version": "1.1.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080e1d",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080e1d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rookmoney.app",
      "buildNumber": "2"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#080e1d"
      },
      "package": "com.rookmoney.app",
      "versionCode": 2,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-haptics",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite anexar capturas de tela ao feedback.",
          "cameraPermission": "Permite tirar foto para anexar ao feedback."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      }
    }
  }
}
