{
  "expo": {
    "name": "Rook Money",
    "slug": "rook-money",
    "scheme": "rookmoney",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#080e1d",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080e1d"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rookmoney.app",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rookmoney.app",
      "versionCode": 24,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.RECORD_AUDIO",
        "com.android.vending.BILLING"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#080e1d",
          "defaultChannel": "default"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite anexar capturas de tela ao feedback.",
          "cameraPermission": "Permite tirar foto para anexar ao feedback."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "48ed8ac5-7530-48b9-a722-46769e9e96a6"
      }
    },
    "owner": "rookmoneybr"
  }
}
